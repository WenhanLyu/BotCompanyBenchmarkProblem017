add_user -c alice -p pass -n Alice -m a@m.com -g 10
login -c alice -p pass
add_train -i T1 -n 2 -m 100 -s A|B -p 0|100 -x 08:00 -t 60 -o 06-01|06-10 -d 06-01 -y N
