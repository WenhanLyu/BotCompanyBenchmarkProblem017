add_user -c alice -p password123 -n Alice -m alice@test.com -g 5
login -c alice -p password123
add_train -i T001 -n 3 -m 100 -s Shanghai|Nanjing|Beijing -p 0|300|600 -x 08:00 -t 120|180 -o 06-01|06-30 -d 06-01 -y N
release_train -i T001
